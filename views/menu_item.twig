{% from "macros.html.twig" import btn %}

 
<li class="d-flex flex-column gap-2 border p-2 position-relative" style="width: 210px">
    <div class="position-absolute" style="right: 4px; top: 4px">
        <form action="/brands-object/{{object.id}}/delete" method="post">
            <button type="submit" class="btn btn-danger">
                <i class="fas fa-times"></i>
            </button>
        </form>
    </div>
    <div class="position-absolute" style="right: 45px; top: 4px">
        <form action="/brands-object/{{object.id}}/edit">
            <button type="submit" class="btn btn-warning">
                <i class="fa-regular fa-pen-to-square"></i>
            </button>
        </form>
    </div>
    <div class="d-flex justify-content-center border" style="height: 210px;">
        <img src="{{ object.image }}" alt="" class="img-fluid rounded p-1" style="height: 100%; width: auto; object-fit: contain;">
    </div>
    <div class="d-flex flex-column gap-2 w-100 p-2">
        {{ btn(object.title, "/brands-object/" ~ object.id, true) }}
        
        <div class="d-flex justify-content-center">
            {{ btn("Картинка", "/brands-object/" ~ object.id ~ "?show=image", false) }}
            {{ btn("Описание", "/brands-object/" ~ object.id ~ "?show=info", false) }}
        </div>
    </div>
</li>