{% from "macros.html.twig" import btn %}


<div class="col">
	<div class="card h-100 shadow-sm border p-2 position-relative">

		<div class="position-absolute d-flex gap-1" style="right: 8px; top: 8px;">
			<a href="/brands-object/{{object.id}}/edit" class="btn btn-sm btn-warning">
				<i class="fa-regular fa-pen-to-square"></i>
			</a>
			<form action="/brands-object/{{object.id}}/delete" method="post" class="d-inline">
				<button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Удалить?')">
					<i class="fas fa-times"></i>
				</button>
			</form>
		</div>
		<div class="d-flex justify-content-center align-items-center border rounded" style="height: 180px;">
			<img src="{{ object.image }}" alt="{{ object.title }}" class="img-fluid p-2" style="max-height: 100%; object-fit: contain;">
		</div>
		<div class="card-body d-flex flex-column gap-2 p-2">
			<h5 class="card-title d-grid text-center mb-0">
				{{ btn(object.title, "/brands-object/" ~ object.id, true) }}
			</h5>

			<div class="d-flex justify-content-around gap-1 mt-auto">
				{{ btn("Картинка", "/brands-object/" ~ object.id ~ "?show=image", false) }}
				{{ btn("Описание", "/brands-object/" ~ object.id ~ "?show=info", false) }}
			</div>
		</div>
	</div>
</div>
