{% from "macros.html.twig" import btn %}

 
<li class="d-flex flex-column gap-2 border p-2" style="width: 210px;">
    <div class="d-flex justify-content-center border">
        <img src="{{ object.image }}" alt="" class="img-fluid rounded p-1">
    </div>
    <div class="d-flex flex-column gap-2 w-100 p-2">
        {{ btn(object.title, "/brands-object/" ~ object.id, true) }}
        
        <div class="d-flex justify-content-center">
            {{ btn("Картинка", "/brands-object/" ~ object.id ~ "?show=image", false) }}
            {{ btn("Описание", "/brands-object/" ~ object.id ~ "?show=info", false) }}
        </div>
    </div>
</li>